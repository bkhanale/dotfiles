{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 90,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(echo *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(head *)",
      "Bash(lsof *)",
      "Bash(which *)",
      "Bash(grep *)",
      "Bash(curl *)",
      "Bash(psql *)",
      "Bash(pnpm *)",
      "Bash(gh *)",
      "Bash(git *)",
      "Bash(npx *)",
      "Bash(bd *)",
      "Bash(dolt *)",
      "Bash(node *)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(gcloud *)",
      "Bash(terraform fmt *)",
      "Bash(terraform validate *)",
      "Bash(terraform plan *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "WebSearch",
      "WebFetch",
      "Read(/tmp/**)",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__navigate_page",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__take_screenshot",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__take_snapshot",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__click",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__fill",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__list_pages",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__list_network_requests",
      "mcp__plugin_chrome-devtools-mcp_chrome-devtools__get_network_request"
    ],
    "deny": [],
    "defaultMode": "bypassPermissions",
    "additionalDirectories": [
      "~/workspace"
    ]
  },
  "enableAllProjectMcpServers": false,
  "statusLine": {
    "type": "command",
    "command": "ccstatusline",
    "padding": 0,
    "refreshInterval": 10
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "chrome-devtools-mcp@chrome-devtools-plugins": true
  },
  "extraKnownMarketplaces": {
    "chrome-devtools-plugins": {
      "source": {
        "source": "github",
        "repo": "ChromeDevTools/chrome-devtools-mcp"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "awaySummaryEnabled": true,
  "tui": "fullscreen",
  "voice": {
    "enabled": true,
    "mode": "hold",
    "autoSubmit": false
  },
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "editorMode": "vim",
  "showTurnDuration": true
}
