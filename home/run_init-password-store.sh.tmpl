#!/usr/bin/env bash
# Initialize pass (passwordstore.org) with this machine's GPG key.
#
# Deliberately `run_` (every apply), NOT `run_once_`: on a fresh machine the
# first `chezmoi apply` usually runs before the GPG key has been generated, and
# a run_once_ script that skipped would never fire again. Every guard below
# exits 0 fast, so re-runs are free.
set -euo pipefail

{{ if not .gpgKey -}}
# No gpgKey configured for this machine — nothing to do.
exit 0
{{- end }}

if ! command -v pass >/dev/null 2>&1 || ! command -v gpg >/dev/null 2>&1; then
  exit 0
fi

store="${PASSWORD_STORE_DIR:-$HOME/.password-store}"
if [[ -f "$store/.gpg-id" ]]; then
  # Already initialized (or cloned from another device) — leave it alone.
  exit 0
fi

if ! gpg --list-secret-keys "{{ .gpgKey }}" >/dev/null 2>&1; then
  echo "pass: GPG secret key {{ .gpgKey }} not found yet; skipping store init (will retry on next chezmoi apply)" >&2
  exit 0
fi

pass init "{{ .gpgKey }}"
pass git init
echo "pass: initialized $store for key {{ .gpgKey }}"
echo "pass: for multi-device sync, use a self-hosted bare repo (see 'pass — Secrets Vault' in AGENTS.md)"
