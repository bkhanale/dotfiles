# secrets.zsh.example — copy to secrets.zsh and add your tokens / passwords
#
# secrets.zsh is gitignored AND in home/.chezmoiignore — chezmoi will never
# overwrite it on `chezmoi apply`, so you can edit it freely on each machine.
#
# Usage:
#   cp ~/.config/zsh/secrets.zsh.example ~/.config/zsh/secrets.zsh
#   chmod 600 ~/.config/zsh/secrets.zsh
#   $EDITOR ~/.config/zsh/secrets.zsh
#
# Use this file for *secrets* (tokens, API keys, passwords). Use local.zsh
# for non-secret per-machine config (PATH additions, work-only aliases, etc).

# Examples — replace with your own:
# export GITHUB_TOKEN="ghp_..."
# export OPENAI_API_KEY="sk-..."
# export AWS_PROFILE="personal"
