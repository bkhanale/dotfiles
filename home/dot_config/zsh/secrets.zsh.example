# secrets.zsh.example — copy to secrets.zsh and add your tokens / passwords
#
# secrets.zsh is gitignored AND in home/.chezmoiignore — chezmoi will never
# overwrite it on `chezmoi apply`, so you can edit it freely on each machine.
#
# Usage:
#   cp ~/.config/zsh/secrets.zsh.example ~/.config/zsh/secrets.zsh
#   chmod 600 ~/.config/zsh/secrets.zsh
#   $EDITOR ~/.config/zsh/secrets.zsh
#
# Use this file for *secrets* (tokens, API keys, passwords). Use local.zsh
# for non-secret per-machine config (PATH additions, work-only aliases, etc).

# Prefer pulling secrets from pass (the local GPG-encrypted vault — see
# "pass — Secrets Vault" in AGENTS.md) over pasting plaintext values here.
#
# Startup env vars: keep them in ONE multiline entry (`pass edit env/shell`,
# containing `export FOO=...` lines) and eval it with a single gpg spawn —
# one `pass show` per variable would cost ~190ms EACH at every shell startup:
# _pass_env="${PASSWORD_STORE_DIR:-$HOME/.password-store}/env/shell.gpg"
# if [[ -f "$_pass_env" ]] && command -v gpg >/dev/null 2>&1; then
#   eval "$(gpg -dq --batch "$_pass_env" 2>/dev/null)"
# fi
# unset _pass_env
#
# On-demand secrets (not needed in every shell) get their own entries:
# pass insert ai/openai-api-key      # store
# openai-key() { pass show ai/openai-api-key; }   # lazy: cost only on use

# Plaintext examples — replace with your own (last resort):
# export GITHUB_TOKEN="ghp_..."
# export OPENAI_API_KEY="sk-..."
# export AWS_PROFILE="personal"
