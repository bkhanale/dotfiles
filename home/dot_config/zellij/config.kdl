// zellij config.kdl — Zellij terminal multiplexer configuration
// Theme: Tokyo Night Dark (built-in)

// ── Shell ─────────────────────────────────────────────────────────────────────
default_shell "zsh"

// ── Layout ────────────────────────────────────────────────────────────────────
default_layout "default"
layout_dir "~/.config/zellij/layouts"

// ── Behaviour ─────────────────────────────────────────────────────────────────
default_mode "locked"
show_startup_tips false
mouse_mode true
copy_on_select false
scroll_buffer_size 10000
copy_clipboard "system"
scrollback_editor "nvim"

// ── UI ────────────────────────────────────────────────────────────────────────
pane_frames true
auto_layout true
session_serialization true

// ── Theme ────────────────────────────────────────────────────────────────────
theme "tokyo-night-dark"

// ── Keybindings ───────────────────────────────────────────────────────────────
keybinds {
    locked {
        // Pane navigation (vim-style only)
        // NOTE: avoid Alt+<letter> bindings that clash with the terminal's
        // Opt+arrow escape sequences: b (back-word), f (fwd-word), d (del-word)
        bind "Alt h" { MoveFocusOrTab "Left"; }
        bind "Alt l" { MoveFocusOrTab "Right"; }
        bind "Alt j" { MoveFocus "Down"; }
        bind "Alt k" { MoveFocus "Up"; }

        // Quick actions (avoid switching modes for common operations)
        bind "Alt n" { NewPane; }
        bind "Alt t" { NewTab; }
        bind "Alt w" { CloseFocus; }
        bind "Alt Shift f" { ToggleFocusFullscreen; }
        bind "Alt [" { PreviousSwapLayout; }
        bind "Alt ]" { NextSwapLayout; }

        // Tab movement
        bind "Alt i" { MoveTab "Left"; }
        bind "Alt o" { MoveTab "Right"; }

        // Tab navigation
        bind "Alt 1" { GoToTab 1; }
        bind "Alt 2" { GoToTab 2; }
        bind "Alt 3" { GoToTab 3; }
        bind "Alt 4" { GoToTab 4; }
        bind "Alt 5" { GoToTab 5; }
        bind "Alt 6" { GoToTab 6; }
        bind "Alt 7" { GoToTab 7; }
        bind "Alt 8" { GoToTab 8; }
        bind "Alt 9" { GoToTab 9; }

        // Copy mouse selection to system clipboard
        bind "Alt c" { Copy; }

        // Enter scroll mode for scrollback navigation
        bind "Alt s" { SwitchToMode "Scroll"; }
    }

    scroll {
        bind "j" "Down" { ScrollDown; }
        bind "k" "Up" { ScrollUp; }
        bind "Ctrl f" "PageDown" { PageScrollDown; }
        bind "Ctrl b" "PageUp" { PageScrollUp; }
        bind "d" { HalfPageScrollDown; }
        bind "u" { HalfPageScrollUp; }
        bind "e" { EditScrollback; SwitchToMode "Normal"; }
        bind "s" { SwitchToMode "EnterSearch"; SearchInput 0; }
        bind "Alt c" { Copy; }
        bind "Esc" { ScrollToBottom; SwitchToMode "Locked"; }
    }

    entersearch {
        bind "Ctrl c" "Esc" { SwitchToMode "Scroll"; }
        bind "Enter" { SwitchToMode "Search"; }
    }

    search {
        bind "j" "Down" { ScrollDown; }
        bind "k" "Up" { ScrollUp; }
        bind "Ctrl f" "PageDown" { PageScrollDown; }
        bind "Ctrl b" "PageUp" { PageScrollUp; }
        bind "d" { HalfPageScrollDown; }
        bind "u" { HalfPageScrollUp; }
        bind "n" { Search "down"; }
        bind "p" { Search "up"; }
        bind "c" { SearchToggleOption "CaseSensitivity"; }
        bind "w" { SearchToggleOption "Wrap"; }
        bind "o" { SearchToggleOption "WholeWord"; }
        bind "Alt c" { Copy; }
        bind "Esc" { ScrollToBottom; SwitchToMode "Locked"; }
    }
}